# App Configuration
NEXT_PUBLIC_ENVIRONMENT=development

# Smart Contract Addresses (set after deployment)
NEXT_PUBLIC_CONTRACT_ACTIVITY_MANAGER=0x...
NEXT_PUBLIC_CONTRACT_REWARD_DISTRIBUTOR=0x...
NEXT_PUBLIC_CONTRACT_MICRO_ACTIONS=0x...
NEXT_PUBLIC_CONTRACT_LEADERBOARD=0x...
NEXT_PUBLIC_CONTRACT_REFERRAL_SYSTEM=0x...

# Blockscout API
NEXT_PUBLIC_BLOCKSCOUT_API=https://explorer.celo.org/mainnet/api
NEXT_PUBLIC_BLOCKSCOUT_API_KEY=your_blockscout_api_key_here

# Celo Network
NEXT_PUBLIC_CHAIN_ID=42220
NEXT_PUBLIC_RPC_URL=https://forno.celo.org

# Deployment (only needed for contract deployment)
DEPLOYER_PRIVATE_KEY=0x...

# ERC-8004 Agent Trust Protocol (Identity + Reputation Registries)
# Get addresses from: https://docs.celo.org/build-on-celo/build-with-ai/8004#contract-deployments
NEXT_PUBLIC_ERC8004_IDENTITY_REGISTRY=0x...
NEXT_PUBLIC_ERC8004_REPUTATION_REGISTRY=0x...

# x402 Micropayment Settings
NEXT_PUBLIC_X402_RECIPIENT_ADDRESS=0x...

# thirdweb x402 Protocol (optional — for full thirdweb SDK integration)
# Get client ID from: https://thirdweb.com/dashboard
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id

